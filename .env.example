BOT_TOKEN=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=incident_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Used for local (non-docker) runs. In docker compose this is overridden
# to http://report-service:8000 automatically.
REPORT_SERVICE_URL=http://localhost:8000

# Optional Telegraph access token for publishing incident timelines.
# Leave empty to create an anonymous account on first use.
TELEGRAPH_ACCESS_TOKEN=

# HTTP API serving incidents to the frontend.
HTTP_ADDR=:8080
CORS_ALLOWED_ORIGIN=*

# Incidents opened from an existing Prometheus/Alertmanager. Point your
# Alertmanager webhook_configs at http://<host>:8080/webhooks/alertmanager.
# ALERT_CHAT_ID is the forum supergroup (bot must be admin with Manage Topics)
# where alert incidents are opened; leave empty to disable the webhook.
ALERT_CHAT_ID=
# Optional shared secret. When set, the webhook requires
# "Authorization: Bearer <token>"; configure it in Alertmanager http_config.
ALERTMANAGER_WEBHOOK_TOKEN=

# Set to true to allow attaching a single photo per message to the timeline.
# When false, images are rejected with a "storage not connected" message.
S3_ENABLED=false

S3_ENDPOINT_URL=https://s3.storage.selcloud.ru
S3_REGION=ru-1
S3_BUCKET_NAME=your_bucket_name
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_PUBLIC_BASE_URL=https://(some_value).selstorage.ru


DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
