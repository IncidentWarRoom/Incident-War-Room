# Base URL of the incident-service (list, detail, timeline, images)
VITE_INCIDENT_API_BASE=http://localhost:8080

# Base URL of the report-service (only used if/when report generation
# is triggered from the frontend - currently the frontend only displays
# the reportUrl that already exists on an incident, see the open question
# about this in the feature list document).
#
# Note: report-service-openapi.yaml says port 8001, but the real
# docker-compose.yml runs it on 8000 and only exposes it inside the
# Docker network (not to the host). Using the actual port here in case
# this ever gets wired up - worth flagging the spec/compose mismatch to
# whoever owns that file.
VITE_REPORT_API_BASE=http://localhost:8000
