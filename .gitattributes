# Normalize all text files to LF in the repository, regardless of the
# contributor's OS. Prevents CRLF noise from Windows/WSL checkouts.
* text=auto eol=lf

# Keep shell scripts and Go/Python sources LF explicitly.
*.go    text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf

# Binary assets must never be normalized.
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
